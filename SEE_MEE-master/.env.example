# API Configuration (Vite — use your deployed API origin in production)
VITE_API_URL=http://localhost:5000

# Razorpay Configuration (Frontend)
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# MongoDB Connection
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?appName=SEEMEE

# JWT Secret
JWT_SECRET=your_long_random_jwt_secret_here

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Server Configuration
PORT=5000
NODE_ENV=development

# Razorpay Configuration (Backend)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
